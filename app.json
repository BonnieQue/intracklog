{
  "expo": {
    "name": "InTrackLog",
    "slug": "intracklog",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "intracklog",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0c"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.intracklog.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0c"
      },
      "package": "com.intracklog.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      "expo-splash-screen",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "InTrackLog needs your location to track trips automatically."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "InTrackLog needs camera access to capture receipts.",
          "photosPermission": "InTrackLog needs photo library access to attach receipts."
        }
      ],
      "expo-document-picker",
      "expo-screen-orientation"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bcc075f6-cb71-49ca-b22f-02a49eac0136"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/bcc075f6-cb71-49ca-b22f-02a49eac0136"
    }
  }
}
